# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# PROXY_SECRET_KEY: 你的跨国通信验证密码 (Your cross-border authentication password)
# 国内服务器调用本接口时，必须在头部带上此密码。防止别人盗刷你的 API。
# 请在左侧栏设置一个属于你自己的密码。
PROXY_SECRET_KEY="my_secure_password_123"

# IP_WHITELIST: 白名单 IP 地址。在白名单中的 IP 放开并发限制，支持高达 8 路的高并发流。
# 填入白名单的 IP 必须用逗号分隔，不要带有括号。如 (CN) 等地信息由自动拦截器给出，此处仅填源 IP。
IP_WHITELIST="127.0.0.1,::1,114.252.1.1"

# 第三方模型配置 (Optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=
MIDJOURNEY_API_KEY=
MIDJOURNEY_BASE_URL=
FLUX_API_KEY=
FLUX_BASE_URL=
MJ_MODE=openai

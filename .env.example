# ==============================================================================
# Universal AI Gateway - 环境变量示例 (.env.example)
# 将此文件复制为 .env 并填入对应的 API Key
# ==============================================================================

# 服务配置
PORT=3000
NODE_ENV=production
# 外部访问公网链接 (例: http://47.79.225.28 或 https://gateway.domain.com), 用于向可灵/即梦等视频模型传递可被其公用服务器下载垫图的临时 URL. 留空则默认依请求头动态生成。
PUBLIC_APP_URL=
# 外部网关转发目标 (用于国内阿里云/腾讯云等服务器，无感调度和中转您的新加坡网关)
# 只要在您的国内阿里云服务器网站的 .env 中填入新加坡网关项目的公网链接 (如 http://172.96.160.174:3000)，该网站的所有模型请求就会一键、无缝地委派中转给新加坡网关服务器处理！
EXTERNAL_GATEWAY_URL=

# 核心凭证
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# 图像/视频模型凭证
MIDJOURNEY_API_KEY=
MIDJOURNEY_BASE_URL=
FLUX_API_KEY=
FLUX_BASE_URL=

# 即梦 Jimeng (火山引擎 Ark)
JIMENG_API_KEY=
JIMENG_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 可灵 Kling AI
KLING_API_KEY=
KLING_BASE_URL=https://api.klingai.com/v1

# 管理员配置 (用于设置面板)
# 暂时在 server.ts 中硬编码或通过此变量传递
ADMIN_PASSWORD=admin123
